@{
    ViewBag.Title = "Home";
}

<div class="text-center" style="padding: 40px 0 20px 0;">
    <h1><i class="fas fa-dumbbell"></i> Gym Manager</h1>
    <p class="lead">Manage members, classes and bookings all in one place.</p>
    <hr />
</div>

<div class="row text-center">
    <div class="col-md-4">
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h3><i class="fas fa-users"></i> Members</h3>
                <p>Register new members, update details, manage wallets and memberships.</p>
                <hr />
                @Html.ActionLink("Register Member", "Register", "Member", null, new { @class = "btn btn-primary m-1" })
                @Html.ActionLink("Update Member", "Update", "Member", null, new { @class = "btn btn-secondary m-1" })
                @Html.ActionLink("Add Funds", "AddFunds", "Member", null, new { @class = "btn btn-secondary m-1" })
                @Html.ActionLink("Renew", "Renew", "Member", null, new { @class = "btn btn-secondary m-1" })
                @Html.ActionLink("Close Membership", "Close", "Member", null, new { @class = "btn btn-danger m-1" })
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h3><i class="fas fa-calendar-alt"></i> Classes</h3>
                <p>Schedule new gym classes and cancel existing ones.</p>
                <hr />
                @Html.ActionLink("Schedule Class", "Schedule", "Class", null, new { @class = "btn btn-primary m-1" })
                @Html.ActionLink("Cancel Class", "Cancel", "Class", null, new { @class = "btn btn-danger m-1" })
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h3><i class="fas fa-clipboard-list"></i> Bookings</h3>
                <p>Book members into classes, cancel bookings and view revenue reports.</p>
                <hr />
                @Html.ActionLink("Book a Class", "Book", "Booking", null, new { @class = "btn btn-primary m-1" })
                @Html.ActionLink("Cancel Booking", "Cancel", "Booking", null, new { @class = "btn btn-danger m-1" })
                @Html.ActionLink("Revenue Report", "Revenue", "Booking", null, new { @class = "btn btn-secondary m-1" })
            </div>
        </div>
    </div>
</div>